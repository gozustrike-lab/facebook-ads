# =============================================
# ImmiScale Meta Engine v5 - Global Edition
# Variables de Entorno — Mobile-First + Supabase
# =============================================

# =============================================
# SUPABASE (NUEVO - REQUERIDO)
# Crear proyecto en: https://supabase.com
# =============================================
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."

# =============================================
# Base de Datos (Legacy - migrar a Supabase)
# =============================================
DATABASE_URL="file:./db/custom.db"

# =============================================
# Meta / Facebook Developer API
# Obtén estas credenciales en: https://developers.facebook.com/
# NOTA: Con OAuth 1-clic, solo necesitas APP_ID y APP_SECRET
# El ACCESS_TOKEN, AD_ACCOUNT_ID, PIXEL_ID se auto-detectan via OAuth
# =============================================
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID="act_123456789"
META_PIXEL_ID=""
META_BUSINESS_ID=""

# Facebook Login for Business Configuration ID
# Obtén este ID en: https://developers.facebook.com/ > Tu App > Facebook Login for Business > Configurations
# Sin este ID, Meta retorna "Content not found" para apps Business
NEXT_PUBLIC_META_CONFIG_ID=""

# Webhook Verify Token (genera uno aleatorio seguro)
META_WEBHOOK_VERIFY_TOKEN=""

# Graph API Version
META_GRAPH_API_VERSION="v21.0"

# =============================================
# Stripe (Pagos Internacionales)
# =============================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# =============================================
# Pasarelas Locales (Perú/Latam)
# =============================================
MERCADOPAGO_ACCESS_TOKEN=""
NIUBIZ_MERCHANT_ID=""
NIUBIZ_ACCESS_KEY=""
CULQI_PUBLIC_KEY=""
CULQI_SECRET_KEY=""

# =============================================
# IA Express (para Modo IA Express de campañas)
# =============================================
DEEPSEEK_API_KEY=""
# QWEN_API_KEY=""

# =============================================
# App Config
# =============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
