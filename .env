# PostgreSQL — Supabase Pooler URL (para Vercel serverless)
# Obtiene tu URL en: Supabase Dashboard > Settings > Database > Connection string > URI
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# ⚠️ Usa el POOLER (puerto 6543) para Vercel, NO la conexión directa (puerto 5432)
DATABASE_URL=postgresql://postgres:password@localhost:5432/immiscale

# Facebook Login for Business — Configuration ID
# Get this from: https://developers.facebook.com/ > Your App > Facebook Login for Business > Configurations
NEXT_PUBLIC_META_CONFIG_ID=
