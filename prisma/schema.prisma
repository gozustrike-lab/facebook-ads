// ImmiScale Meta Engine v5 - Global Edition
// Schema de Base de Datos Multinacional

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================
// REGIÓN / CONFIGURACIÓN POR PAÍS
// =============================================
model Region {
  id            String   @id @default(cuid())
  code          String   @unique  // "US", "PE", "CO", "MX", "GLOBAL"
  name          String             // "Estados Unidos", "Perú", "Colombia"
  currency      String   @default("USD")  // Moneda local: USD, PEN, COP, MXN
  cplTarget     Float    @default(25.0)   // Costo por Lead objetivo en moneda local
  cplKillSwitch Float    @default(37.5)   // 1.5x CPL para kill-switch
  language      String   @default("es")   // Idioma principal del chatbot
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  adSets   AdSet[]
  leads    Lead[]
  metrics  Metric[]
}

// =============================================
// CAMPAÑAS META ADS
// =============================================
model Campaign {
  id              String   @id @default(cuid())
  metaCampaignId  String?             // ID de la campaña en Meta
  name            String
  objective       String   @default("LEAD_GENERATION")
  status          String   @default("ACTIVE")  // ACTIVE, PAUSED, KILLED, COMPLETED
  totalBudget     Float    @default(0)
  totalSpend      Float    @default(0)
  matchScore      Float    @default(0)    // Meta Match Score (0-100)
  autoScale       Boolean  @default(true) // Escalado automático habilitado
  lastScaledAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  adSets AdSet[]
}

// =============================================
// ADSETS - CONJUNTOS DE ANUNCIOS
// =============================================
model AdSet {
  id             String   @id @default(cuid())
  metaAdSetId    String?             // ID del adset en Meta
  name           String
  campaignId     String
  regionId       String
  budget         Float               // Presupuesto diario
  budgetCurrency String   @default("USD")
  dailySpend     Float    @default(0)
  cpl            Float    @default(0)      // Costo por Lead actual
  leadCount      Int      @default(0)
  audienceType   String   @default("BROAD") // BROAD, LOOKALIKE, CUSTOM
  targetingJson  String?             // JSON con configuración de targeting
  status         String   @default("ACTIVE") // ACTIVE, PAUSED, KILLED, LEARNING
  scaleDirection String?             // "H" (horizontal), "V" (vertical), null
  lastBudgetInc  DateTime?
  killSwitchTriggered Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  region   Region   @relation(fields: [regionId], references: [id])

  @@index([campaignId])
  @@index([regionId])
}

// =============================================
// LEADS - PRE-CALIFICADOS
// =============================================
model Lead {
  id              String   @id @default(cuid())
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  country         String             // País de origen detectado
  regionId        String
  route           String             // "IN_COUNTRY_US" o "OUT_COUNTRY_GLOBAL"
  visaType        String?            // ASILO, EB2_NIW, H1B, FAMILY, WORK, OTHER
  hasCriminalRecord Boolean? 
  investmentCapacity String?         // "LOW", "MEDIUM", "HIGH"
  hasUniversityDegree Boolean?
  hasUsFamily     Boolean?
  solvencyVerified Boolean?
  qualificationScore Float  @default(0)  // 0-100 score de calificación
  status          String   @default("NEW") // NEW, QUALIFIED, DISQUALIFIED, CONTACTED, PAID, LOST
  chatSessionId   String?
  source          String   @default("META_ADS") // META_ADS, ORGANIC, REFERRAL
  metaAdId        String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  region   Region   @relation(fields: [regionId], references: [id])
  payments Payment[]

  @@index([regionId])
  @@index([status])
  @@index([route])
}

// =============================================
// PAGOS - MULTIDIVISA
// =============================================
model Payment {
  id              String   @id @default(cuid())
  leadId          String
  amount          Float
  currency        String   @default("USD")  // USD, PEN, COP, MXN
  amountUsd       Float    @default(0)       // Monto convertido a USD
  exchangeRate    Float    @default(1)
  gateway         String   @default("STRIPE") // STRIPE, MERCADO_PAGO, NIUBIZ, CULQI
  gatewayRefId    String?                    // Referencia del gateway
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  description     String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@index([gateway])
}

// =============================================
// MÉTRICAS DIARIAS POR REGIÓN
// =============================================
model Metric {
  id              String   @id @default(cuid())
  regionId        String
  date            DateTime             // Fecha de la métrica
  totalSpend      Float    @default(0) // Gasto total del día
  leadCount       Int      @default(0) // Leads totales
  qualifiedCount  Int      @default(0) // Leads calificados
  paidCount       Int      @default(0) // Consultas pagadas
  cpql            Float    @default(0) // Costo por Lead Calificado
  cpl             Float    @default(0) // Costo por Lead
  revenue         Float    @default(0) // Ingresos del día (USD)
  matchScore      Float    @default(0) // Meta Match Score promedio
  currency        String   @default("USD")
  createdAt       DateTime @default(now())

  region Region @relation(fields: [regionId], references: [id])

  @@unique([regionId, date])
  @@index([regionId])
  @@index([date])
}

// =============================================
// SESIONES DE CHATBOT
// =============================================
model ChatSession {
  id              String   @id @default(cuid())
  visitorId       String              // ID del visitante (cookie/fingerprint)
  country         String?             // País detectado/pregunta
  route           String?             // Ruta asignada: IN_COUNTRY_US, OUT_COUNTRY_GLOBAL
  currentStep     String  @default("GREETING") // Paso actual del flujo
  answersJson     String?             // JSON con respuestas del usuario
  qualificationResult String?         // Resultado de pre-calificación
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([visitorId])
  @@index([route])
}

// =============================================
// EVENTOS CAPI (Meta Conversions API)
// =============================================
model CAPIEvent {
  id              String   @id @default(cuid())
  eventId         String              // ID único del evento para deduplicación
  eventName       String              // Lead, Purchase, CompleteRegistration
  sourceUrl       String?             // URL de origen
  country         String?             // País del lead
  userAgent       String?
  ipHash          String?             // Hash de IP (privacidad)
  fbclid          String?             // Facebook Click ID
  fbp             String?             // Facebook Browser ID
  eventTime       DateTime @default(now())
  sentToMeta      Boolean  @default(false)
  metaResponse    String?
  createdAt       DateTime @default(now())

  @@index([eventName])
  @@index([country])
  @@index([sentToMeta])
}

// =============================================
// CREDENCIALES META / FACEBOOK DEV
// =============================================
model MetaCredential {
  id                String   @id @default(cuid())
  appId             String              // Facebook App ID
  appSecret         String              // Facebook App Secret (encriptado en producción)
  accessToken       String              // Token de acceso de larga duración
  tokenExpiresAt    DateTime?           // Fecha de expiración del token
  refreshToken      String?             // Token de refresco
  accountId         String?             // Ad Account ID (act_xxxxx)
  pixelId           String?             // Meta Pixel ID
  businessId        String?             // Business Manager ID
  graphApiVersion   String   @default("v21.0") // Versión de la Graph API
  scope             String?             // Permisos otorgados (JSON)
  isConnected       Boolean  @default(false)    // Estado de la conexión
  lastSyncAt        DateTime?           // Última sincronización exitosa
  connectionStatus  String   @default("DISCONNECTED") // DISCONNECTED, CONNECTED, ERROR, EXPIRED
  errorMessage      String?             // Último mensaje de error
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
